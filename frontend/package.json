{
  "name": "servereye-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:next",
    "dev:next": "next dev -p 3000",
    "build": "doppler run --config prd npm run build:next",
    "build:next": "next build",
    "build:production": "NODE_ENV=production doppler run --config prd npm run build:next",
    "start": "doppler run --config prd npm run start:next",
    "start:next": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "doppler run --config prd npm run type-check:next",
    "type-check:next": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "analyze": "ANALYZE=true doppler run --config prd npm run build:next",
    "secrets:sync": "doppler secrets download --format env --config dev > .env.local",
    "secrets:status": "doppler secrets status",
    "secrets:audit": "doppler audit logs --limit 50",
    "secrets:production": "doppler secrets download --format env --config prd > .env.production.local",
    "audit:fix": "npm audit fix",
    "audit:check": "npm audit",
    "deps:check": "npm outdated",
    "deps:update": "npm update"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-web": "^1.26.0",
    "@opentelemetry/instrumentation": "^0.53.0",
    "@opentelemetry/instrumentation-fetch": "^0.53.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.53.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.53.0",
    "@opentelemetry/resources": "^1.26.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "axios": "^1.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.344.0",
    "next": "^15.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.1.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "15.1.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "postcss": "^8",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "overrides": {
    "glob": "^10.4.0",
    "minimatch": "^9.0.0",
    "ajv": "^6.14.0",
    "js-yaml": "^4.1.0"
  }
}
