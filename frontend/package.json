{
  "name": "servereye-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:next",
    "dev:next": "next dev -p 3000",
    "build": "npm run build:next",
    "build:next": "next build",
    "build:production": "NODE_ENV=production npm run build:next",
    "build:doppler": "doppler run --config prd npm run build:next",
    "start": "npm run start:next",
    "start:next": "next start",
    "start:doppler": "doppler run --config prd npm run start:next",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "npm run type-check:next",
    "type-check:next": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "analyze": "ANALYZE=true doppler run --config prd npm run build:next",
    "secrets:sync": "doppler secrets download --format env --config dev > .env.local",
    "secrets:status": "doppler secrets status",
    "secrets:audit": "doppler audit logs --limit 50",
    "secrets:production": "doppler secrets download --format env --config prd > .env.production.local",
    "audit:fix": "npm audit fix",
    "audit:check": "npm audit",
    "deps:check": "npm outdated",
    "deps:update": "npm update"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/instrumentation-fetch": "^0.214.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "axios": "^1.15.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "autoprefixer": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": "25",
    "npm": ">=8.0.0"
  },
  "overrides": {
    "glob": "^10.4.0",
    "minimatch": "^9.0.0",
    "ajv": "^6.14.0",
    "js-yaml": "^4.1.0"
  }
}
