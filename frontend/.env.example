# Environment variables for ServerEye Frontend

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://api.servereye.com/api
NEXT_PUBLIC_WS_URL=wss://api.servereye.com/ws

# Authentication
NEXT_PUBLIC_COOKIE_DOMAIN=.servereye.com
NEXTAUTH_URL=https://servereye.com
NEXTAUTH_SECRET=your-secret-key-here

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SENTRY=true
NEXT_PUBLIC_ENABLE_CRISP_CHAT=true

# Third-party services
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
NEXT_PUBLIC_CRISP_WEBSITE_ID=your-crisp-id

# Application settings
NEXT_PUBLIC_APP_NAME=ServerEye
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SUPPORT_EMAIL=support@servereye.com

# Development/Debug
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=error
