# Frontend Production Secrets (Template - use Doppler for real values)
# This file contains all frontend-specific secrets for production

# API Configuration (Production)
NEXT_PUBLIC_API_BASE_URL=https://api.servereye.com/api
NEXT_PUBLIC_WS_URL=wss://api.servereye.com/ws

# Authentication (Production - use Doppler)
NEXT_PUBLIC_COOKIE_DOMAIN=.servereye.com
NEXTAUTH_URL=https://servereye.com
NEXTAUTH_SECRET=${NEXTAUTH_SECRET}

# Feature Flags (Production)
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SENTRY=true
NEXT_PUBLIC_ENABLE_CRISP_CHAT=true

# Application Settings (Production)
NEXT_PUBLIC_APP_NAME=ServerEye
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SUPPORT_EMAIL=support@servereye.com

# Development/Debug (Production)
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=error
NEXT_PUBLIC_SHOW_CONSOLE_ERRORS=false

# Third-party Services (Production - use Doppler)
NEXT_PUBLIC_SENTRY_DSN=${SENTRY_DSN}
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=${GOOGLE_ANALYTICS_ID}
NEXT_PUBLIC_CRISP_WEBSITE_ID=${CRISP_WEBSITE_ID}

# Performance (Production)
NEXT_PUBLIC_ENABLE_BUNDLE_ANALYZER=false
NEXT_PUBLIC_DISABLE_JS_MINIFICATION=false

# Security Headers (Production)
NEXT_PUBLIC_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https: wss:; frame-ancestors 'none';

# Node Environment
NODE_ENV=production
