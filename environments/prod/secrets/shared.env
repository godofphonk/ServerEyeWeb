# Shared Production Secrets (Template - use Doppler for real values)
# This file contains secrets shared between backend and frontend

# JWT Configuration (Production - use RSA keys from Doppler)
JWT_PRIVATE_KEY_BASE64=${JWT_PRIVATE_KEY_BASE64}
JWT_PUBLIC_KEY_BASE64=${JWT_PUBLIC_KEY_BASE64}
JWT_ISSUER=ServerEye
JWT_AUDIENCE=ServerEye-Web
JWT_ACCESS_TOKEN_EXPIRATION=01:00:00
JWT_REFRESH_TOKEN_EXPIRATION=7.00:00:00
JWT_EXPIRATION_MINUTES=60

# OAuth Configuration (Production - use Doppler)
# Google OAuth
OAUTH_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
OAUTH_GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}
OAUTH_GOOGLE_REDIRECT_URI=https://api.servereye.com/api/auth/oauth/callback
OAUTH_GOOGLE_ENABLED=true

# GitHub OAuth
OAUTH_GITHUB_CLIENT_ID=${GITHUB_CLIENT_ID}
OAUTH_GITHUB_CLIENT_SECRET=${GITHUB_CLIENT_SECRET}
OAUTH_GITHUB_REDIRECT_URI=https://api.servereye.com/api/auth/oauth/callback
OAUTH_GITHUB_ENABLED=true

# Telegram OAuth
OAUTH_TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
OAUTH_TELEGRAM_REDIRECT_URI=https://servereye.com/telegram-callback
OAUTH_TELEGRAM_ENABLED=true
TELEGRAM_BOT_USERNAME=ServerEyeBot

# Security Settings (Production)
SECURITY_PASSWORD_MIN_LENGTH=8
SECURITY_REQUIRE_DIGIT=true
SECURITY_REQUIRE_UPPERCASE=true
SECURITY_REQUIRE_LOWERCASE=true
SECURITY_REQUIRE_NON_ALPHANUMERIC=true
SECURITY_MAX_LOGIN_ATTEMPTS=5
SECURITY_LOCKOUT_MINUTES=15
