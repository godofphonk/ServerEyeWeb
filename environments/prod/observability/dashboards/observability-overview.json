{
  "dashboard": {
    "title": "ServerEye - Observability Stack Overview",
    "tags": ["servereye", "observability", "system"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "panels": [
      {
        "id": 1,
        "title": "Service Health Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "up{job=~\"prometheus|loki|tempo|grafana|alloy\"}",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"displayMode": "list", "orientation": "horizontal"},
            "mappings": [
              {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
            ],
            "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
          }
        },
        "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}}
      },
      {
        "id": 2,
        "title": "Database Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "up{job=~\"postgres-main|redis\"}",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"displayMode": "list", "orientation": "horizontal"},
            "mappings": [
              {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
            ],
            "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
          }
        }
      },
      {
        "id": 3,
        "title": "Container Resource Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{name=~\"ServerEyeWeb-.*\"}[5m]) * 100",
            "legendFormat": "{{name}} CPU",
            "refId": "A"
          },
          {
            "expr": "container_memory_usage_bytes{name=~\"ServerEyeWeb-.*\"} / 1024 / 1024",
            "legendFormat": "{{name}} Memory MB",
            "refId": "B"
          }
        ],
        "yAxes": [{"label": "CPU % / Memory MB"}, {}],
        "lines": true,
        "fill": 1,
        "linewidth": 1
      },
      {
        "id": 4,
        "title": "Request Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{status}}",
            "refId": "A"
          }
        ],
        "yAxes": [{"label": "Requests/sec"}, {}],
        "lines": true,
        "fill": 1
      },
      {
        "id": 5,
        "title": "Response Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "50th percentile",
            "refId": "B"
          }
        ],
        "yAxes": [{"label": "Seconds"}, {}],
        "lines": true,
        "fill": 1
      },
      {
        "id": 6,
        "title": "Alerts Status",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "ALERTS",
            "legendFormat": "{{alertname}}",
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "__name__": true, "severity": false},
              "indexByName": {},
              "renameByName": {"alertname": "Alert", "instance": "Instance", "job": "Job"}
            }
          }
        ]
      }
    ],
    "time": {"from": "now-1h", "to": "now"}
  }
}
