# Doppler Production Configuration
# This file defines the secrets and configuration for production environment
# Use: doppler secrets download --config=production > .env.prod

# === Database Configuration ===
POSTGRES_HOST=your-production-db-host.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DATABASE=ServerEyeWeb_Prod
POSTGRES_USERNAME=servereye_prod_user
POSTGRES_PASSWORD=your-secure-postgres-password

TICKET_POSTGRES_HOST=your-ticket-db-host.rds.amazonaws.com
TICKET_POSTGRES_PORT=5432
TICKET_POSTGRES_DATABASE=ServerEyeWeb_Ticket_Prod
TICKET_POSTGRES_USERNAME=servereye_ticket_user
TICKET_POSTGRES_PASSWORD=your-secure-ticket-db-password

# === Redis Configuration ===
REDIS_HOST=your-redis-cluster.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password

# === JWT RSA Keys ===
# Generate with: openssl genrsa -out private.pem 2048
# Then: openssl rsa -in private.pem -pubout -out public.pem
# Convert to base64: base64 -w 0 private.pem
JWT_PRIVATE_KEY_BASE64=your-base64-encoded-private-key-here
JWT_PUBLIC_KEY_BASE64=your-base64-encoded-public-key-here

# === Go API Configuration ===
GO_API_API_KEY=sk_production_api_key_change_me
GO_API_TIMEOUT_SECONDS=10

# === Email Configuration ===
SMTP_HOST=email-smtp.eu-north-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# AWS SES Configuration
AWS_REGION=eu-north-1
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key

# === OAuth Configuration ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# === Frontend Configuration ===
NEXTAUTH_SECRET=your-nextauth-secret-key-256-bits
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
CRISP_WEBSITE_ID=your-crisp-website-id

# === Monitoring Configuration ===
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
DATADOG_API_KEY=your-datadog-api-key

# === Security Configuration ===
ENCRYPTION_KEY=your-32-character-encryption-key-here

# === Doppler Configuration ===
DOPPLER_PROJECT=servereye
DOPPLER_CONFIG=production
DOPPLER_TOKEN=your-doppler-service-token

# === SSL Certificates (for HTTPS) ===
# These should be mounted as files, not environment variables
# SSL_CERT_PATH=/etc/ssl/certs/servereye.com.crt
# SSL_KEY_PATH=/etc/ssl/private/servereye.com.key
