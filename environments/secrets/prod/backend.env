# Backend Production Secrets (Template - use Doppler for real values)
# This file contains all backend-specific secrets for production

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80
ASPNETCORE_HTTP_PORTS=80
ASPNETCORE_HTTPS_PORTS=443

# Database Configuration (Production - use Doppler)
DATABASE_HOST=${POSTGRES_HOST}
DATABASE_PORT=5432
DATABASE_NAME=${POSTGRES_DATABASE}
DATABASE_USER=${POSTGRES_USER}
DATABASE_PASSWORD=${POSTGRES_PASSWORD}

TICKET_DB_HOST=${TICKET_POSTGRES_HOST}
TICKET_DB_PORT=5432
TICKET_DB_NAME=${TICKET_POSTGRES_DATABASE}
TICKET_DB_USER=${TICKET_POSTGRES_USER}
TICKET_DB_PASSWORD=${TICKET_POSTGRES_PASSWORD}

# Redis Configuration (Production - use Doppler)
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_INSTANCE_NAME=ServerEye:

# Email Configuration (Production - use Doppler)
EMAIL_SMTP_HOST=${SMTP_HOST}
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=${SMTP_USERNAME}
EMAIL_SMTP_PASSWORD=${SMTP_PASSWORD}
EMAIL_FROM_EMAIL=support@servereye.com
EMAIL_FROM_NAME=ServerEye Support
EMAIL_SUPPORT_EMAIL=support@servereye.com
EMAIL_FRONTEND_URL=https://servereye.com
EMAIL_ENABLE_SSL=true
EMAIL_USE_AWS_SES=true
EMAIL_AWS_REGION=${AWS_REGION}
EMAIL_AWS_ACCESS_KEY=${AWS_ACCESS_KEY}
EMAIL_AWS_SECRET_KEY=${AWS_SECRET_KEY}

# Go API Configuration (Production)
GO_API_BASE_URL=https://api.servereye.dev
GO_API_API_KEY=${GO_API_API_KEY}
GO_API_SERVICE_ID=csharp-backend
GO_API_TIMEOUT_SECONDS=10

# Security Configuration (Production - strict)
SECURITY_REQUIRE_HTTPS=true
SECURITY_ENABLE_TOKEN_BLACKLIST=true
SECURITY_ENABLE_RATE_LIMITING=true
SECURITY_ENABLE_AUDIT_LOGGING=true
SECURITY_LOCKOUT_THRESHOLD=5
SECURITY_LOCKOUT_DURATION=00:15:00

# Rate Limiting (Production - strict)
RATE_LIMITING_PERMIT_LIMIT=100
RATE_LIMITING_WINDOW_SECONDS=60
RATE_LIMITING_QUEUE_LIMIT=10

# Server Configuration (Production - no mock data)
SERVERS_USE_MOCK_DATA=false
SERVERS_MOCK_DATA_DELAY_MS=0
SERVERS_ENABLE_DETAILED_LOGGING=false
SERVERS_MAX_SERVERS_PER_USER=1000

# Cache Configuration (Production - longer TTL)
CACHE_LIVE_METRICS=00:00:30
CACHE_HOUR_METRICS=00:30:00
CACHE_DAY_METRICS=02:00:00
CACHE_MONTH_METRICS=06:00:00
CACHE_SERVER_LIST=00:05:00

# Logging Configuration (Production - minimal)
LOGGING_DEFAULT_LEVEL=Warning
LOGGING_MICROSOFT_ASPNETCORE=Warning
LOGGING_SERVEREYE=Information

# Encryption Configuration (Production - use Doppler)
ENCRYPTION_KEY=${ENCRYPTION_KEY}

# CORS Configuration (Production - strict)
CORS_ALLOWED_ORIGINS=https://servereye.com,https://app.servereye.com,https://admin.servereye.com

# Monitoring Configuration (Production)
SENTRY_DSN=${SENTRY_DSN}
DATADOG_API_KEY=${DATADOG_API_KEY}
HEALTH_CHECK_ENABLED=true
