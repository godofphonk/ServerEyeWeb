# Backend Development Secrets
# This file contains all backend-specific secrets for development

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:80
ASPNETCORE_HTTP_PORTS=80
ASPNETCORE_HTTPS_PORTS=443

# Database Configuration (Development)
DATABASE_HOST=postgres-main
DATABASE_PORT=5432
DATABASE_NAME=ServerEyeWeb_Dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL_MODE=Disable

TICKET_DB_HOST=postgres-ticket
TICKET_DB_PORT=5432
TICKET_DB_NAME=ServerEyeWeb_Dev_Ticket
TICKET_DB_USER=postgres
TICKET_DB_PASSWORD=postgres
TICKET_DB_SSL_MODE=Disable

# Connection Strings for Entity Framework
DATABASE_CONNECTION_STRING=Host=postgres-main;Port=5432;Database=ServerEyeWeb_Dev;Username=postgres;Password=postgres;SSL Mode=Disable;
TICKET_DB_CONNECTION_STRING=Host=postgres-ticket;Port=5432;Database=ServerEyeWeb_Dev_Ticket;Username=postgres;Password=postgres;SSL Mode=Disable;

# Redis Configuration (Development)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_INSTANCE_NAME=ServerEye:
REDIS_CONNECTION_STRING=servereye-redis-dev:6379

# Email Configuration (Development - use Mailtrap)
EMAIL_SMTP_HOST=smtp.mailtrap.io
EMAIL_SMTP_PORT=2525
EMAIL_SMTP_USERNAME=dev_mailtrap_username
EMAIL_SMTP_PASSWORD=dev_mailtrap_password
EMAIL_FROM_EMAIL=dev@servereye.local
EMAIL_FROM_NAME=ServerEye Dev
EMAIL_SUPPORT_EMAIL=dev-support@servereye.local
EMAIL_FRONTEND_URL=http://127.0.0.1:3000
EMAIL_ENABLE_SSL=false
EMAIL_USE_AWS_SES=false

# Go API Configuration (Development)
GO_API_BASE_URL=http://127.0.0.1:8080
GO_API_API_KEY=dev_api_key_change_in_production
GO_API_SERVICE_ID=csharp-backend-dev
GO_API_TIMEOUT_SECONDS=5

# Security Configuration (Development - relaxed)
SECURITY_REQUIRE_HTTPS=false
SECURITY_ENABLE_TOKEN_BLACKLIST=true
SECURITY_ENABLE_RATE_LIMITING=true
SECURITY_ENABLE_AUDIT_LOGGING=true
SECURITY_LOCKOUT_THRESHOLD=10
SECURITY_LOCKOUT_DURATION=00:05:00

# Rate Limiting (Development - lenient)
RATE_LIMITING_PERMIT_LIMIT=200
RATE_LIMITING_WINDOW_SECONDS=60
RATE_LIMITING_QUEUE_LIMIT=20

# Server Configuration (Development)
SERVERS_USE_MOCK_DATA=true
SERVERS_MOCK_DATA_DELAY_MS=1
SERVERS_ENABLE_DETAILED_LOGGING=true
SERVERS_MAX_SERVERS_PER_USER=100

# Cache Configuration (Development - shorter TTL)
CACHE_LIVE_METRICS=00:01:00
CACHE_HOUR_METRICS=00:05:00
CACHE_DAY_METRICS=00:15:00
CACHE_MONTH_METRICS=01:00:00
CACHE_SERVER_LIST=00:10:00

# Logging Configuration (Development)
LOGGING_DEFAULT_LEVEL=Information
LOGGING_MICROSOFT_ASPNETCORE=Warning
LOGGING_SERVEREYE=Debug

# Encryption Configuration (Development)
ENCRYPTION_KEY=dev_encryption_key_32_characters_long

# CORS Configuration (Development)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://127.0.0.1:3001
