# Frontend Development Secrets for Docker Environment
# This file contains frontend-specific secrets for Docker containers

# API Configuration (Docker - use service names)
NEXT_PUBLIC_API_BASE_URL=http://backend:8080/api
NEXT_PUBLIC_API_URL=http://backend:8080
NEXT_PUBLIC_WS_URL=ws://backend:8080/ws

# Authentication (Docker)
NEXT_PUBLIC_COOKIE_DOMAIN=127.0.0.1
NEXTAUTH_URL=http://127.0.0.1:3000
NEXTAUTH_SECRET=dev-nextauth-secret-key-change-in-production

# Feature Flags (Docker)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_ENABLE_CRISP_CHAT=false

# Application Settings (Docker)
NEXT_PUBLIC_APP_NAME=ServerEye Dev
NEXT_PUBLIC_APP_VERSION=1.0.0-dev
NEXT_PUBLIC_SUPPORT_EMAIL=dev-support@servereye.local

# Development/Debug (Docker)
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_LOG_LEVEL=debug
NEXT_PUBLIC_SHOW_CONSOLE_ERRORS=true

# Third-party Services (Docker - disabled)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Performance (Docker)
NEXT_PUBLIC_ENABLE_BUNDLE_ANALYZER=true
NEXT_PUBLIC_DISABLE_JS_MINIFICATION=true

# Node Environment
NODE_ENV=development
