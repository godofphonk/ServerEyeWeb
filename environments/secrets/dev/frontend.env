# Frontend Development Secrets
# This file contains all frontend-specific secrets for development

# API Configuration (Development)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5246/api
NEXT_PUBLIC_WS_URL=ws://localhost:5246/ws

# Authentication (Development)
NEXT_PUBLIC_COOKIE_DOMAIN=localhost
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-key-change-in-production

# Feature Flags (Development)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_ENABLE_CRISP_CHAT=false

# Application Settings (Development)
NEXT_PUBLIC_APP_NAME=ServerEye Dev
NEXT_PUBLIC_APP_VERSION=1.0.0-dev
NEXT_PUBLIC_SUPPORT_EMAIL=dev-support@servereye.local

# Development/Debug (Development)
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_LOG_LEVEL=debug
NEXT_PUBLIC_SHOW_CONSOLE_ERRORS=true

# Third-party Services (Development - disabled)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Performance (Development)
NEXT_PUBLIC_ENABLE_BUNDLE_ANALYZER=true
NEXT_PUBLIC_DISABLE_JS_MINIFICATION=true

# Node Environment
NODE_ENV=development
