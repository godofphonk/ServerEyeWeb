{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ServerEyeDbContext": "Host=localhost;Port=5432;Database=ServerEyeWeb;Username=postgres;Password=postgres",
    "TicketDbContext": "Host=localhost;Port=5434;Database=ServerEyeWeb-ticket;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-jwt-key-change-in-production-32-chars",
    "Issuer": "ServerEye",
    "Audience": "ServerEye-Web",
    "AccessTokenExpiration": "01:00:00",
    "RefreshTokenExpiration": "7.00:00:00",
    "ExpirationMinutes": 60
  },
  "Security": {
    "RequireHttps": true,
    "EnableTokenBlacklist": true,
    "EnableRateLimiting": true,
    "EnableAuditLogging": true,
    "LockoutThreshold": 5,
    "LockoutDuration": "00:15:00"
  },
  "SecuritySettings": {
    "PasswordMinLength": 8,
    "RequireDigit": true,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireNonAlphanumeric": true,
    "MaxLoginAttempts": 5,
    "LockoutMinutes": 15
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:5173"
    ],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["*"],
    "AllowCredentials": true
  },
  "GoApiSettings": {
    "BaseUrl": "http://ServereyeAPI-api:8080",
    "ProductionUrl": "https://api.servereye.dev",
    "ApiKey": "sk_csharp_backend_development_key_change_in_production",
    "ServiceId": "csharp-backend",
    "TimeoutSeconds": 5
  },
  "CacheSettings": {
    "LiveMetrics": "00:01:00",
    "HourMetrics": "00:05:00",
    "DayMetrics": "00:15:00",
    "MonthMetrics": "01:00:00",
    "ServerList": "00:10:00"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "ServerEye:"
  },
  "Encryption": {
    "Key": "your-32-character-encryption-key-here-change-in-prod"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 10
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "your-email@gmail.com",
    "SmtpPassword": "your-app-password",
    "FromEmail": "noreply@servereye.dev",
    "FromName": "ServerEye Support",
    "SupportEmail": "support@servereye.dev",
    "EnableSsl": true
  }
}
