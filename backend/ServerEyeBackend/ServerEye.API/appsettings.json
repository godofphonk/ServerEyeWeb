{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ServerEyeDbContext": "User ID=postgres;Password=postgres;Host=localhost;Port=5432;Database=ServerEyeWeb;"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-that-should-be-at-least-256-bits-long-for-production",
    "Issuer": "ServerEyeAPI",
    "Audience": "ServerEyeClient",
    "AccessTokenExpiration": "00:30:00",
    "RefreshTokenExpiration": "7.00:00:00"
  },
  "Security": {
    "RequireHttps": true,
    "EnableTokenBlacklist": true,
    "EnableRateLimiting": true,
    "EnableAuditLogging": true,
    "LockoutThreshold": 5,
    "LockoutDuration": "00:15:00"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "http://localhost:3001"],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["*"],
    "AllowCredentials": true
  },
  "GoApiSettings": {
    "BaseUrl": "http://localhost:8080",
    "ProductionUrl": "https://api.servereye.dev",
    "ApiKey": "",
    "ServiceId": "csharp-backend",
    "TimeoutSeconds": 30
  },
  "CacheSettings": {
    "LiveMetrics": "00:01:00",
    "HourMetrics": "00:05:00",
    "DayMetrics": "00:15:00",
    "MonthMetrics": "01:00:00",
    "ServerList": "00:10:00"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "ServerEye:"
  }
}
