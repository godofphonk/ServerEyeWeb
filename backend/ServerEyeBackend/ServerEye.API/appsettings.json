{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ServerEyeDbContext": "Host=localhost;Port=5433;Database=ServerEyeWeb_Dev;Username=postgres;Password=postgres",
    "TicketDbContext": "Host=localhost;Port=5434;Database=ServerEyeWeb_Dev_Ticket;Username=postgres;Password=postgres",
    "BillingDbContext": "Host=localhost;Port=5436;Database=ServerEyeWeb_Dev_Billing;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-development-key-that-is-at-least-256-bits-long",
    "Issuer": "ServerEyeAPI",
    "Audience": "ServerEyeClient",
    "AccessTokenExpiration": "00:30:00",
    "RefreshTokenExpiration": "7.00:00:00"
  },
  "Security": {
    "RequireHttps": false,
    "EnableTokenBlacklist": true,
    "EnableRateLimiting": true,
    "EnableAuditLogging": true,
    "LockoutThreshold": 5,
    "LockoutDuration": "00:15:00"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ],
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
    "AllowedHeaders": [ "*" ],
    "AllowCredentials": true
  },
  "RedisSettings": {
    "ConnectionString": "127.0.0.1:6379",
    "InstanceName": "ServerEye:"
  },
  "EmailSettings": {
    "EnableEmailVerification": false
  },
  "Authentication": {
    "RequireEmailVerification": false
  },
  "PostgreSQLMonitoring": {
    "MainDatabaseConnectionString": "Host=localhost;Port=5433;Database=ServerEyeWeb_Dev;Username=postgres;Password=postgres",
    "TicketsDatabaseConnectionString": "Host=localhost;Port=5434;Database=ServerEyeWeb_Dev_Ticket;Username=postgres;Password=postgres",
    "BillingDatabaseConnectionString": "Host=localhost;Port=5436;Database=ServerEyeWeb_Dev_Billing;Username=postgres;Password=postgres",
    "MetricsUpdateIntervalSeconds": 30
  }
}
