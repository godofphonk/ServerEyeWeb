{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ServerEyeDbContext": "CHANGE_ME_USE_ENVIRONMENT_VARIABLE_DATABASE_CONNECTION_STRING",
    "TicketDbContext": "CHANGE_ME_USE_ENVIRONMENT_VARIABLE_TICKET_DB_CONNECTION_STRING"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_USE_DOPPLER_JWT_SECRET_KEY",
    "Issuer": "ServerEye",
    "Audience": "ServerEye-Web",
    "AccessTokenExpiration": "01:00:00",
    "RefreshTokenExpiration": "7.00:00:00",
    "ExpirationMinutes": 60
  },
  "Security": {
    "RequireHttps": true,
    "EnableTokenBlacklist": true,
    "EnableRateLimiting": true,
    "EnableAuditLogging": true,
    "LockoutThreshold": 5,
    "LockoutDuration": "00:15:00"
  },
  "SecuritySettings": {
    "PasswordMinLength": 8,
    "RequireDigit": true,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireNonAlphanumeric": true,
    "MaxLoginAttempts": 5,
    "LockoutMinutes": 15
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:5173"
    ],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["*"],
    "AllowCredentials": true
  },
  "GoApiSettings": {
    "BaseUrl": "http://ServereyeAPI-api:8080",
    "ProductionUrl": "https://api.servereye.dev",
    "ApiKey": "sk_csharp_backend_development_key_change_in_production",
    "ServiceId": "csharp-backend",
    "TimeoutSeconds": 5
  },
  "CacheSettings": {
    "LiveMetrics": "00:01:00",
    "HourMetrics": "00:05:00",
    "DayMetrics": "00:15:00",
    "MonthMetrics": "01:00:00",
    "ServerList": "00:10:00"
  },
  "Redis": {
    "ConnectionString": "CHANGE_ME_USE_ENVIRONMENT_VARIABLE_REDIS_CONNECTION_STRING",
    "InstanceName": "ServerEye:"
  },
  "Encryption": {
    "Key": "CHANGE_ME_USE_DOPPLER_ENCRYPTION_KEY"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 10
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "CHANGE_ME_USE_DOPPLER_SMTP_USERNAME",
    "SmtpPassword": "CHANGE_ME_USE_DOPPLER_SMTP_PASSWORD",
    "FromEmail": "support@servereye.dev",
    "FromName": "ServerEye Support",
    "SupportEmail": "support@servereye.dev",
    "EnableSsl": true,
    "UseAwsSes": true,
    "AwsRegion": "eu-north-1",
    "AwsAccessKey": "",
    "AwsSecretKey": "",
    "FrontendUrl": "http://localhost:3000"
  }
}
