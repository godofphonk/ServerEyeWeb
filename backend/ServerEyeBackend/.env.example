# Environment variables for ServerEye Backend
# Copy this file to .env and fill in your values

# Doppler Configuration
DOPPLER_TOKEN=your_doppler_token_here
DOPPLER_PROD_TOKEN=your_production_doppler_token_here

# Database Configuration (for local development without Doppler)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ServerEyeWeb
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

TICKET_DB_HOST=localhost
TICKET_DB_PORT=5434
TICKET_DB_NAME=ServerEyeWeb-ticket
TICKET_DB_USER=postgres
TICKET_DB_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration (for local development only)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-32-chars
JWT_ISSUER=ServerEye
JWT_AUDIENCE=ServerEye-Web

# Encryption Configuration (for local development only)
ENCRYPTION_KEY=your-32-character-encryption-key-here-change-in-prod

# Email Configuration (for local development only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=support@servereye.dev
FROM_NAME=ServerEye Support

# Go API Configuration
GO_API_BASE_URL=http://ServereyeAPI-api:8080
GO_API_TIMEOUT_SECONDS=5

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Security Configuration
REQUIRE_HTTPS=true
ENABLE_RATE_LIMITING=true
RATE_LIMITING_PERMIT_LIMIT=100
RATE_LIMITING_WINDOW_SECONDS=60

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
